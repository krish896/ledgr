{
  "info": {
    "name": "Ledgr API",
    "description": "Complete QA collection for Ledgr — expense-splitting backend. Covers Auth, Groups, Members, Expenses, Balances, and Settlements with happy-path, error, and end-to-end regression flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "groupId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "aliceId", "value": "" },
    { "key": "bobId", "value": "" },
    { "key": "regEmail", "value": "" },
    { "key": "bobEmail", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "User registration, login, session management, and profile retrieval.",
      "item": [
        {
          "name": "Register",
          "description": "Create a new user account. Uses a timestamp-suffixed email to avoid conflicts on repeated runs.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('dynamicEmail', `user_${Date.now()}@test.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returns user object', () => {",
                  "  pm.expect(body).to.have.property('user');",
                  "  const u = body.user;",
                  "  pm.expect(u.id).to.be.a('string');",
                  "  pm.expect(u.email).to.be.a('string');",
                  "  pm.expect(u.profileCompleted).to.be.a('boolean').and.equal(false);",
                  "  pm.expect(u).to.not.have.property('passwordHash');",
                  "  pm.expect(Date.parse(u.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(u.updatedAt)).to.not.be.NaN;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"{{dynamicEmail}}\", \"password\": \"password123\" }"
            }
          }
        },
        {
          "name": "Register – Duplicate Email",
          "description": "Registering with an already-used email must return 409.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"alice@example.com\", \"password\": \"password123\" }"
            }
          }
        },
        {
          "name": "Register – Invalid Password",
          "description": "Password shorter than 8 characters must return 400.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"short@example.com\", \"password\": \"abc\" }"
            }
          }
        },
        {
          "name": "Login",
          "description": "Authenticate with valid credentials. The server sets an HTTP-only cookie that Postman's cookie jar carries forward automatically.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns user object', () => {",
                  "  pm.expect(body).to.have.property('user');",
                  "  const u = body.user;",
                  "  pm.expect(u.id).to.be.a('string');",
                  "  pm.expect(u.email).to.be.a('string');",
                  "  pm.expect(u.profileCompleted).to.be.a('boolean');",
                  "  pm.expect(u).to.not.have.property('passwordHash');",
                  "  pm.expect(Date.parse(u.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(u.updatedAt)).to.not.be.NaN;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"alice@example.com\", \"password\": \"password123\" }"
            }
          }
        },
        {
          "name": "Login – Wrong Password",
          "description": "Invalid credentials must return 401.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"alice@example.com\", \"password\": \"wrongpassword\" }"
            }
          }
        },
        {
          "name": "Me",
          "description": "Fetch the authenticated user's profile using the session cookie.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns user object', () => {",
                  "  pm.expect(body).to.have.property('user');",
                  "  const u = body.user;",
                  "  pm.expect(u.id).to.be.a('string');",
                  "  pm.expect(u.email).to.be.a('string');",
                  "  pm.expect(u.profileCompleted).to.be.a('boolean');",
                  "  pm.expect(u).to.not.have.property('passwordHash');",
                  "  pm.expect(Date.parse(u.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(u.updatedAt)).to.not.be.NaN;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Me – Unauthenticated",
          "description": "Calling /auth/me without a session cookie must return 401.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Cookie", "value": "", "disabled": true }]
          }
        },
        {
          "name": "Logout",
          "description": "Clear the session cookie. Subsequent authenticated requests must be rejected.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Groups",
      "description": "Create and manage expense groups.",
      "item": [
        {
          "name": "Create Group",
          "description": "Create a new group. The creator is automatically added as a member. Saves groupId for downstream requests.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returns group object', () => {",
                  "  pm.expect(body).to.have.property('group');",
                  "  const g = body.group;",
                  "  pm.expect(g.id).to.be.a('string');",
                  "  pm.expect(g.name).to.be.a('string');",
                  "  pm.expect(Date.parse(g.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(g.updatedAt)).to.not.be.NaN;",
                  "});",
                  "pm.collectionVariables.set('groupId', body.group.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Trip to Goa\", \"description\": \"Summer 2025\" }"
            }
          }
        },
        {
          "name": "Create Group – Missing Name",
          "description": "Omitting the required name field must return 400.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"description\": \"no name\" }"
            }
          }
        },
        {
          "name": "Get Groups",
          "description": "List all groups the authenticated user belongs to.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns groups array', () => {",
                  "  pm.expect(body).to.have.property('groups').that.is.an('array');",
                  "  if (body.groups.length > 0) {",
                  "    const g = body.groups[0];",
                  "    pm.expect(g.id).to.be.a('string');",
                  "    pm.expect(g.name).to.be.a('string');",
                  "    pm.expect(Date.parse(g.createdAt)).to.not.be.NaN;",
                  "    pm.expect(Date.parse(g.updatedAt)).to.not.be.NaN;",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups"
          }
        },
        {
          "name": "Get Group By ID",
          "description": "Retrieve a single group including its active member list.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns group with members', () => {",
                  "  pm.expect(body).to.have.property('group');",
                  "  const g = body.group;",
                  "  pm.expect(g.id).to.be.a('string');",
                  "  pm.expect(g.name).to.be.a('string');",
                  "  pm.expect(g.members).to.be.an('array');",
                  "  pm.expect(Date.parse(g.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(g.updatedAt)).to.not.be.NaN;",
                  "  if (g.members.length > 0) {",
                  "    const m = g.members[0];",
                  "    pm.expect(m.id).to.be.a('string');",
                  "    pm.expect(m.email).to.be.a('string');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups/{{groupId}}"
          }
        },
        {
          "name": "Get Group By ID – Not Found",
          "description": "A non-existent group ID must return 404.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups/nonexistent-group-id"
          }
        },
        {
          "name": "Update Group",
          "description": "Patch a group's name or description.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns updated group', () => {",
                  "  pm.expect(body).to.have.property('group');",
                  "  const g = body.group;",
                  "  pm.expect(g.id).to.be.a('string');",
                  "  pm.expect(g.name).to.equal('Trip to Goa (Updated)');",
                  "  pm.expect(Date.parse(g.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(g.updatedAt)).to.not.be.NaN;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/groups/{{groupId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Trip to Goa (Updated)\" }"
            }
          }
        },
        {
          "name": "Update Group – Empty Body",
          "description": "Sending no fields must return 400 because at least one field is required.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/groups/{{groupId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "description": "Add users to a group by email lookup.",
      "item": [
        {
          "name": "Add Member",
          "description": "Add an existing user to a group by their email address.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returns member object', () => {",
                  "  pm.expect(body).to.have.property('member');",
                  "  const m = body.member;",
                  "  pm.expect(m.id).to.be.a('string');",
                  "  pm.expect(m.email).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/members",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"bob@example.com\" }"
            }
          }
        },
        {
          "name": "Add Member – Already a Member",
          "description": "Adding a user who is already an active member must return 409.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/members",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"bob@example.com\" }"
            }
          }
        },
        {
          "name": "Add Member – User Not Found",
          "description": "Referencing an email that has no account must return 404.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/members",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"ghost@example.com\" }"
            }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "description": "Create, retrieve, and soft-delete group expenses with EQUAL or EXACT splits.",
      "item": [
        {
          "name": "Create Expense – EQUAL Split",
          "description": "Alice pays ₹300 split equally among two participants. Remainder paise are distributed deterministically to the first sorted participant IDs. Saves expenseId.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returns expense object', () => {",
                  "  pm.expect(body).to.have.property('expense');",
                  "  const e = body.expense;",
                  "  pm.expect(e.id).to.be.a('string');",
                  "  pm.expect(e.groupId).to.be.a('string');",
                  "  pm.expect(e.payerId).to.be.a('string');",
                  "  pm.expect(e.amount).to.be.a('string');",
                  "  pm.expect(e.splitType).to.equal('EQUAL');",
                  "  pm.expect(Date.parse(e.occurredAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.updatedAt)).to.not.be.NaN;",
                  "});",
                  "pm.collectionVariables.set('expenseId', body.expense.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"payerId\": \"ALICE_USER_ID\",\n  \"amount\": 30000,\n  \"description\": \"Hotel booking\",\n  \"occurredAt\": \"2025-06-01T00:00:00.000Z\",\n  \"splitType\": \"EQUAL\",\n  \"participants\": [\"ALICE_USER_ID\", \"BOB_USER_ID\"]\n}"
            }
          }
        },
        {
          "name": "Create Expense – EXACT Split",
          "description": "Create an expense with manually specified per-user amounts. Split total must equal the expense amount.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returns expense object', () => {",
                  "  pm.expect(body).to.have.property('expense');",
                  "  const e = body.expense;",
                  "  pm.expect(e.id).to.be.a('string');",
                  "  pm.expect(e.amount).to.be.a('string');",
                  "  pm.expect(e.splitType).to.equal('EXACT');",
                  "  pm.expect(Date.parse(e.occurredAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.updatedAt)).to.not.be.NaN;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"payerId\": \"ALICE_USER_ID\",\n  \"amount\": 10000,\n  \"description\": \"Lunch\",\n  \"occurredAt\": \"2025-06-02T00:00:00.000Z\",\n  \"splitType\": \"EXACT\",\n  \"splits\": [\n    { \"userId\": \"ALICE_USER_ID\", \"amount\": 6000 },\n    { \"userId\": \"BOB_USER_ID\", \"amount\": 4000 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Expense – EXACT Split Mismatch",
          "description": "Split amounts that do not add up to the expense total must return 400.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"payerId\": \"ALICE_USER_ID\",\n  \"amount\": 10000,\n  \"description\": \"Bad split\",\n  \"occurredAt\": \"2025-06-02T00:00:00.000Z\",\n  \"splitType\": \"EXACT\",\n  \"splits\": [\n    { \"userId\": \"ALICE_USER_ID\", \"amount\": 3000 },\n    { \"userId\": \"BOB_USER_ID\", \"amount\": 4000 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Expense – Duplicate Participants",
          "description": "EQUAL split with duplicate participant IDs must return 400.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"payerId\": \"ALICE_USER_ID\",\n  \"amount\": 10000,\n  \"description\": \"Dup participants\",\n  \"occurredAt\": \"2025-06-02T00:00:00.000Z\",\n  \"splitType\": \"EQUAL\",\n  \"participants\": [\"ALICE_USER_ID\", \"ALICE_USER_ID\"]\n}"
            }
          }
        },
        {
          "name": "Get Expense",
          "description": "Retrieve a single expense with its per-user split breakdown.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns expense with participants', () => {",
                  "  pm.expect(body).to.have.property('expense');",
                  "  const e = body.expense;",
                  "  pm.expect(e.id).to.be.a('string');",
                  "  pm.expect(e.amount).to.be.a('string');",
                  "  pm.expect(e.participants).to.be.an('array');",
                  "  pm.expect(Date.parse(e.occurredAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.createdAt)).to.not.be.NaN;",
                  "  pm.expect(Date.parse(e.updatedAt)).to.not.be.NaN;",
                  "  if (e.participants.length > 0) {",
