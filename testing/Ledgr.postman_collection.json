    {
      "name": "Regression Flow",
      "description": "End-to-end flow with two users. Uses timestamp-suffixed emails so repeated runs never conflict. Steps: register both users → login Alice → create group → add Bob → create expense → verify Bob owes Alice → login Bob → settle → verify balance cleared → login Alice → add expense → delete it → verify zeroed balance.",
      "item": [
        {
          "name": "Step 01 – Register Alice",
          "description": "Register the first user (Alice) with a unique timestamped email. Also sets bobEmail with the same timestamp for consistency.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('regEmail', `alice_${ts}@regression.com`);",
                  "pm.collectionVariables.set('bobEmail', `bob_${ts}@regression.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const u = pm.response.json().user;",
                  "pm.test('Alice registered', () => {",
                  "  pm.expect(u.id).to.be.a('string');",
                  "  pm.expect(u.email).to.be.a('string');",
                  "  pm.expect(Date.parse(u.createdAt)).to.not.be.NaN;",
                  "});",
                  "pm.collectionVariables.set('aliceId', u.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"{{regEmail}}\", \"password\": \"password123\" }"
            }
          }
        },
        {
          "name": "Step 02 – Register Bob",
          "description": "Register the second user (Bob) with the same timestamp suffix.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const u = pm.response.json().user;",
                  "pm.test('Bob registered', () => {",
                  "  pm.expect(u.id).to.be.a('string');",
                  "  pm.expect(Date.parse(u.createdAt)).to.not.be.NaN;",
                  "});",
                  "pm.collectionVariables.set('bobId', u.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
